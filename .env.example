# Language for UI and log messages: "en" (default) or "de"
# LANGUAGE=en

# Claude CLI model (alias: opus, sonnet, haiku – or full model name)
# Uses your logged-in Pro account (no API key required)
CLAUDE_MODEL=opus

# Optional path to the claude binary (default: "claude" from PATH)
# CLAUDE_BIN=/usr/local/bin/claude

# Discord Bot Token (https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=

# Discord User ID allowed to talk to the bot and receive all DMs
# Find your own ID: Discord → Settings → Advanced → Developer Mode,
# then right-click your name → "Copy ID"
DISCORD_ALLOWED_USER_ID=

# Heartbeat interval in milliseconds (default: 1800000 = 30 minutes)
# HEARTBEAT_INTERVAL_MS=1800000

# Web server
WEB_PORT=3000
# WEB_HOST=127.0.0.1   # local only (default); 0.0.0.0 for all interfaces

# Maximum size of heartbeat.md in bytes before it gets summarized (default: 50000 = ~50KB)
HEARTBEAT_MAX_SIZE=50000
