# Language for UI and log messages: "en" (default) or "de"
# LANGUAGE=en

# Claude CLI model (alias: opus, sonnet, haiku – or full model name)
# Uses your logged-in Pro account (no API key required)
CLAUDE_MODEL=opus

# Optional path to the claude binary (default: "claude" from PATH)
# CLAUDE_BIN=/usr/local/bin/claude

# Enable or disable Discord integration (default: false)
DISCORD_ENABLED=true

# Discord Bot Token (https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=

# Discord User ID allowed to talk to the bot and receive all DMs
# Find your own ID: Discord → Settings → Advanced → Developer Mode,
# then right-click your name → "Copy ID"
DISCORD_ALLOWED_USER_ID=

# WhatsApp integration — uses your personal WhatsApp account via WhatsApp Web
# WARNING: violates WhatsApp ToS; account ban risk exists
# On first start with WHATSAPP_ENABLED=true, open the Settings tab to scan the QR code.
# Session is saved locally (.wwebjs_auth/) so QR is only needed once.
# WHATSAPP_ENABLED=false
# WHATSAPP_PHONE=+491234567890
# WHATSAPP_SEND_PHONE=+491234567890   # optional: send heartbeat/web UI messages here (defaults to WHATSAPP_PHONE)

# Heartbeat interval in minutes (default: 30)
# HEARTBEAT_INTERVAL_MINS=30

# Cron grace window: how many minutes after the scheduled time a cron task may still execute (default: 30)
# CRONTAB_GRACE_MINS=30

# Web server
WEB_PORT=3000
# WEB_HOST=127.0.0.1   # local only (default); 0.0.0.0 for all interfaces

# Maximum size of heartbeat.md in bytes before it gets summarized (default: 50000 = ~50KB)
HEARTBEAT_MAX_SIZE=50000
